{
  "name": "shell-web",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "org",
  "sourceRoot": "apps/shell/web/src",
  "tags": ["scope:shell", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular-architects/native-federation:build",
      "defaultConfiguration": "production",
      "options": {
        "cacheExternalArtifacts": true
      },
      "configurations": {
        "production": {
          "target": "shell-web:esbuild:production"
        },
        "development": {
          "target": "shell-web:esbuild:development",
          "dev": true
        }
      }
    },
    "serve": {
      "executor": "@angular-architects/native-federation:build",
      "options": {
        "target": "shell-web:serve-original:development",
        "rebuildDelay": 500,
        "cacheExternalArtifacts": true,
        "dev": true,
        "devServer": true,
        "port": 4200
      },
      "configurations": {
        "umdzidzisi": {
          "target": "shell-web:serve-original:umdzidzisi"
        },
        "umtengesi": {
          "target": "shell-web:serve-original:umtengesi"
        }
      }
    },
    "esbuild": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/shell/web",
        "browser": "apps/shell/web/src/main.ts",
        "tsConfig": "apps/shell/web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/shell/web/public"
          }
        ],
        "styles": ["apps/shell/web/src/styles.scss"],
        "polyfills": ["es-module-shims"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "umdzidzisi": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/shell/web/src/environments/environment.ts",
              "with": "apps/shell/web/src/environments/environment.umdzidzisi.ts"
            }
          ]
        },
        "umtengesi": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/shell/web/src/environments/environment.ts",
              "with": "apps/shell/web/src/environments/environment.umtengesi.ts"
            }
          ]
        }
      }
    },
    "serve-original": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "port": 4200
      },
      "configurations": {
        "production": {
          "buildTarget": "shell-web:esbuild:production"
        },
        "development": {
          "buildTarget": "shell-web:esbuild:development"
        },
        "umdzidzisi": {
          "buildTarget": "shell-web:esbuild:umdzidzisi"
        },
        "umtengesi": {
          "buildTarget": "shell-web:esbuild:umtengesi"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "shell-web:build",
        "port": 4200,
        "staticFilePath": "dist/apps/shell/web/browser",
        "spa": true
      }
    }
  }
}

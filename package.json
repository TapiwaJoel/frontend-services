{
  "name": "@mushaviri/web-apps",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "npm run stop && nx run-many -t serve -p shell-web,umdzidzisi-website,umtengesi-website --parallel=3",
    "stop": "lsof -ti :4200 -ti :4201 -ti :4202 -ti :4203 -ti :4204 -ti :4205 -ti :4206 | xargs kill -9 2>/dev/null || true",
    "umdzidzisi:website": "npm run stop && nx run-many -t serve -p shell-web,umdzidzisi-website --parallel=2 -c umdzidzisi",
    "umdzidzisi:admin": "npm run stop && nx run-many -t serve -p shell-admin,umdzidzisi-admin --parallel=2 -c umdzidzisi",
    "umdzidzisi:client": "npm run stop && nx run-many -t serve -p shell-client,umdzidzisi-client --parallel=2 -c umdzidzisi",
    "umtengesi:website": "npm run stop && nx run-many -t serve -p shell-web,umtengesi-website --parallel=2 -c umtengesi",
    "umtengesi:admin": "npm run stop && nx run-many -t serve -p shell-admin,umtengesi-admin --parallel=2 -c umtengesi",
    "umtengesi:client": "npm run stop && nx run-many -t serve -p shell-client,umtengesi-client --parallel=2 -c umtengesi",
    "shell:admin": "npm exec nx serve shell-admin",
    "shell:client": "npm exec nx serve shell-client",
    "shell:web": "npm exec nx serve shell-web",
    "build:all": "nx run-many -t build -p shell-admin,shell-client,shell-web,umdzidzisi-website,umdzidzisi-admin,umdzidzisi-client,umtengesi-website,umtengesi-admin,umtengesi-client",
    "build:remotes": "nx run-many -t build -p umdzidzisi-website,umdzidzisi-admin,umdzidzisi-client,umtengesi-website,umtengesi-admin,umtengesi-client",
    "build:bundle:umdzidzisi-website": "node tools/scripts/build-deployment.mjs bundle umdzidzisi-website",
    "build:bundle:umdzidzisi-admin": "node tools/scripts/build-deployment.mjs bundle umdzidzisi-admin",
    "build:bundle:umdzidzisi-client": "node tools/scripts/build-deployment.mjs bundle umdzidzisi-client",
    "build:bundle:umtengesi-website": "node tools/scripts/build-deployment.mjs bundle umtengesi-website",
    "build:bundle:umtengesi-admin": "node tools/scripts/build-deployment.mjs bundle umtengesi-admin",
    "build:bundle:umtengesi-client": "node tools/scripts/build-deployment.mjs bundle umtengesi-client",
    "build:shared:shell-admin": "node tools/scripts/build-deployment.mjs shared-shell shell-admin",
    "build:shared:shell-client": "node tools/scripts/build-deployment.mjs shared-shell shell-client",
    "build:shared:shell-web": "node tools/scripts/build-deployment.mjs shared-shell shell-web",
    "build:shared:umdzidzisi-website": "node tools/scripts/build-deployment.mjs shared umdzidzisi-website",
    "build:shared:umdzidzisi-admin": "node tools/scripts/build-deployment.mjs shared umdzidzisi-admin",
    "build:shared:umdzidzisi-client": "node tools/scripts/build-deployment.mjs shared umdzidzisi-client",
    "build:shared:umtengesi-website": "node tools/scripts/build-deployment.mjs shared umtengesi-website",
    "build:shared:umtengesi-admin": "node tools/scripts/build-deployment.mjs shared umtengesi-admin",
    "build:shared:umtengesi-client": "node tools/scripts/build-deployment.mjs shared umtengesi-client",
    "e2e:shell:admin": "nx e2e shell-admin-e2e",
    "e2e:shell:client": "nx e2e shell-client-e2e",
    "e2e:shell:web": "nx e2e shell-web-e2e",
    "e2e:umdzidzisi:website": "nx e2e umdzidzisi-website-e2e",
    "e2e:umdzidzisi:admin": "nx e2e umdzidzisi-admin-e2e",
    "e2e:umdzidzisi:client": "nx e2e umdzidzisi-client-e2e",
    "e2e:umtengesi:website": "nx e2e umtengesi-website-e2e",
    "e2e:umtengesi:admin": "nx e2e umtengesi-admin-e2e",
    "e2e:umtengesi:client": "nx e2e umtengesi-client-e2e",
    "e2e:all": "nx run-many -t e2e",
    "e2e:affected": "nx affected -t e2e",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "lint:affected": "nx affected -t lint",
    "lint:affected:fix": "nx affected -t lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,html,css,scss,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,html,css,scss,json,md,yaml,yml}\"",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "21.2.7",
    "@angular/animations": "^21.2.9",
    "@angular/common": "21.2.9",

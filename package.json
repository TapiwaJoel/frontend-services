    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
    "@angular/language-service": "21.2.9",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "23.0.1",
    "@nx/devkit": "23.0.1",
    "@nx/docker": "23.0.1",
    "@nx/esbuild": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/node": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/vitest": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "21.2.7",
    "@softarc/native-federation-orchestrator": "^4.2.2",
    "@swc-node/register": "1.11.1",

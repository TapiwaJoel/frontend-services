    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.3.2",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "8.0.9",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "~4.1.0"
  }
}
